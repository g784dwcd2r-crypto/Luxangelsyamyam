DATABASE_URL=postgresql://user:password@localhost:5432/luxangels
PORT=5000
# Optional values for npm run reset:db
# RESET_OWNER_PIN=1234
# RESET_MANAGER_USERNAME=manager
# RESET_MANAGER_PIN=4321

# Email provider config for platform-sent emails
# EMAIL_PROVIDER=zeptomail
# ZEPTO_API_TOKEN=your-zepto-token
# ZEPTO_API_URL=https://api.zeptomail.eu/v1.1/email
# ZEPTO_FROM_ADDRESS=info@luxangelscleaning.lu
#
# Or use Resend
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=your-resend-api-key
# RESEND_FROM=info@luxangelscleaning.lu

# SMS provider config (Twilio) for platform-sent SMS reminders
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890
